<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/assets/css/main.css" />
  <link rel="stylesheet" href="/assets/css/questionario1.css" />
  <link rel="stylesheet" href="/assets/css/resultado.css" />
  <title>Resultado | Scrum Dungeon</title>
</head>

<body class="corpo-resultado">
  <%- include('partials/header') %>
  <%- include('./partials/botao_voltar') %>

  <main class="tela">
    <section class="resultado-box" aria-labelledby="titulo-resultado">
      <p id="titulo-resultado" class="resultado">RESULTADO</p>
      <div class="linha"></div>

      <div class="corvo-posicao">
        <img src="/assets/img/corvo_feliz.png" alt="Corvo feliz" class="corvo" id="corvoResultado" />
      </div>

      <div class="quadro">
        <div class="quadro-conteudo-topo">
          <p class="quadro-total">Total de Acertos:</p>
          <p class="quadro-nota" id="resultadoAcertos">--/--</p>
        </div>

        <div class="quadro-info-extra">
          <p id="resultadoRespondidas">Total respondidas: --</p>
          <p id="resultadoNotaFinal">Nota final: --%</p>
        </div>

        <div class="quadro-conteudo-meio">
          <p class="quadro-desempenho">Desempenho:</p>
          <p class="quadro-desempenho" id="resultadoDesempenho">Carregando...</p>
        </div>

        <div class="quadro-conteudo-fundo">
          <p class="quadro-tentativas">Tentativas:</p>
          <p class="quadro-numero" id="resultadoTentativas">--</p>
        </div>

        <div class="texto-posicao">
          <p class="quadro-texto" id="resultadoMensagem">
            Carregando o resultado da sua aventura...
          </p>
        </div>
      </div>

      <div class="button-posicao">
        <button class="revisar" id="btnRevisar" type="button" disabled>
          <span class="texto-botao">Revisar</span>
        </button>
        <button class="avancar" id="btnAcaoResultado" type="button" disabled>
          <span class="texto-botao">Carregando...</span>
        </button>
      </div>
    </section>
  </main>
  
 <%- include('partials/navegacao_inferior') %>

  <%- include('partials/footer') %>

  <script src="/js/main.js"></script>
  <script src="/js/resultado.js"></script>
</body>

</html>
