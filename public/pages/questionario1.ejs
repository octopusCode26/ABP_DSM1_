<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/questionario1.css" />
    <title>Questionário 1 | Scrum Dungeon</title>
  </head>

  <body class="pagina-questionario">
    <%- include('partials/header') %> <%- include('./partials/botao_voltar') %>

    <main class="corpo-questionario">
      <section class="tela">
        <section class="progresso-box">
          <div class="progresso-textos">
            <span class="progresso-subtitulo">Progresso</span>
            <strong id="texto-progresso">Questão 1 de 10</strong>
          </div>

          <div
            class="barra-container"
            role="progressbar"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            aria-label="Progresso atual do questionário"
          >
            <div
              id="progresso-dinamico"
              class="barra-preenchimento"
              style="width: 0%"
            ></div>
          </div>

          <p class="progresso-percentual" id="texto-percentual">0%</p>
        </section>

        <section class="questao-box" aria-labelledby="enunciado-questao">
          <p class="dificuldade">
            Dificuldade:
            <strong id="texto-dificuldade">--</strong>
          </p>

          <div class="linha"></div>

          <p id="enunciado-questao" class="questao">Carregando pergunta...</p>

          <div
            id="imagem-questao-container"
            class="imagem-questao-container"
          ></div>
        </section>

        <p class="selecione">Selecione a alternativa correta</p>

        <section
          class="respostas"
          role="group"
          aria-label="Alternativas da questão"
        >
          <button type="button" class="botaoresposta" data-alternativa="a">
            <span class="quadradinho">
              <span class="letraresposta">A</span>
            </span>
            <span class="resposta">Carregando...</span>
          </button>

          <button type="button" class="botaoresposta" data-alternativa="b">
            <span class="quadradinho">
              <span class="letraresposta">B</span>
            </span>
            <span class="resposta">Carregando...</span>
          </button>

          <button type="button" class="botaoresposta" data-alternativa="c">
            <span class="quadradinho">
              <span class="letraresposta">C</span>
            </span>
            <span class="resposta">Carregando...</span>
          </button>

          <button type="button" class="botaoresposta" data-alternativa="d">
            <span class="quadradinho">
              <span class="letraresposta">D</span>
            </span>
            <span class="resposta">Carregando...</span>
          </button>
        </section>

        <section class="botoesdenavegacao">
          <button type="button" class="botaonavegacao">Voltar</button>

          <button type="button" class="confirmar">Confirmar Resposta</button>

          <button type="button" class="botaonavegacao">Pular</button>
        </section>
      </section>
    </main>

    <%- include('partials/navegacao_inferior') %> <%- include('partials/footer')
    %>

    <script src="/js/main.js"></script>
    <script src="/js/questionario1.js"></script>
  </body>
</html>
