<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/assets/css/main.css" />
    <link rel="stylesheet" href="/assets/css/certificado.css" />
    <title>Certificado | Scrum Dungeon</title>
  </head>

  <body class="pagina-certificado">
    <%- include('partials/header') %> <%- include('./partials/botao_voltar') %>

    <div class="certificado-botoes-area">
      <button class="certificado-botoes">
        <img src="../assets/img/botao_temp_download.png" class="icon" />
      </button>

      <button class="certificado-botoes">
        <img src="../assets/img/botao_temp_x.png" class="icon" />
      </button>
    </div>

    <div class="certificado-base">
      <div class="cabecalho">
        <div class="escudo">
          <img src="/assets/img/escudo_certificado.png" />
        </div>
        <div class="logo">
          <img
            src="/assets/img/logo_scrum_detalhada.png"
            alt="Logo do Scrum Dungeon"
          />
          <h1 class="titulo-certificado">Certificado</h1>
          <p>Este certificado é concedido a:</p>
          <h3 class="nome-certificado" id="nome">[Nome do Aluno]</h3>
        </div>

        <div class="corvo-certificado">
          <img src="/assets/img/corvo_certificado.png" />
        </div>
      </div>

      <div class="formulario">
        <div class="cpf" id="cpf">
          <img src="../assets/img/icon_certificado_aluno.PNG" class="icon2" />
          CPF:
        </div>
        <div class="email" id="email">
          <img src="../assets/img/icon_certificado_email.PNG" class="icon2" />
          E-mail:
        </div>
        <div class="dataDeEmissao" id="dataDeEmissao">
          <img src="../assets/img/icon_certificado_data.PNG" class="icon2" />
          Data de Emissão:
        </div>
      </div>

      <div class="media">
        <div><h2>Média Final</h2></div>
        <div class="mediaFinal" id="mediaFinal"></div>
      </div>
      <div class="desempenho-carimbo">
      <div class="container-desempenho">
        <div class="titulo">Desempenho Por Nível</div>

        <div class="niveis">
          <div class="nivel">
            <span>Nível 1</span>
            <div class="linha"></div>
          </div>

          <div class="nivel">
            <span>Nível 2</span>
            <div class="linha"></div>
          </div>

          <div class="nivel">
            <span>Nível 3</span>
            <div class="linha"></div>
          </div>

          <div class="nivel">
            <span>Nível 4</span>
            <div class="linha"></div>
          </div>

          <div class="nivel ultimo">
            <span>Nível 5</span>
            <div class="linha"></div>
          </div>
        </div>
      </div>
      <img src="../assets/img/carimbo_fatec.png" class="carimbo" />
      </div>
    </div>

    <%- include('partials/navegacao_inferior') %> <%- include('partials/footer')
    %>

    <script src="/js/main.js"></script>
  </body>
</html>
