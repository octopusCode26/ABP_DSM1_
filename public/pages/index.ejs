<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="../assets/css/index.css" />
    <link rel="stylesheet" href="../assets/css/main.css" />
    <title>Bem-Vindo | Scrum Dungeon</title>
  </head>

  <body>
    <!-- ALERT -->
    <%- include('partials/alert') %>

    <!-- CABEÇALHO -->
    <%- include('partials/header') %>

    <main>
      <!-- INTRODUÇÃO -->
      <div class="introducao" id="inicio">
        <div class="area_introducao">
          <img
            src="../assets/img/logo_scrum_detalhada.png"
            alt="Logo do Scrum Quest"
            class="logo_introducao"
          />
          <div class="introducao_conteudo">
            <h1>Bem-Vindo ao Scrum Dungeon!</h1>
            <p>
              Você está pronto para aprender os segredos do Scrum Master? Inicie
              uma aventura imersiva de ensino para você entender de uma vez por
              todas o método ágil de Scrum! Deseja embarcar nessa jornada hoje?
            </p>
            <div class="botoes">
              <div class="area_button_cadastro">
                <button class="button_novo_cadastro" id="ir_cadastro">
                  Retomar jornada
                </button>
                <span class="span">Continuar jogo?</span>
              </div>
              <div class="area_button_login">
                <button class="button_login_cadastro" id="ir_login">
                  Nova jornada
                </button>
                <span class="span">Primeira vez aqui?</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- SOBRE O PROJETO -->
      <div class="conteudo" id="sobre">
        <div class="area_conteudo">
          <div class="titulo_conteudo">
            <h2>Sobre o Projeto</h2>
          </div>
          <div class="texto_conteudo">
            <p>
              Scrum Dungeon é uma experiência interativa que transforma o
              aprendizado da metodologia Scrum em uma jornada imersiva inspirada
              em jogos de RPG. Ao longo da aventura, o usuário assume o papel de
              um personagem que precisa explorar uma dungeon, enfrentar desafios
              e reunir artefatos enquanto aprende, na prática, os conceitos
              fundamentais do Scrum.
            </p>
            <img src="../assets/img/corvo.png" class="corvo_sobre_projeto" />
            <p>
              Surge através do desafio proposto como metodologia de ensino no
              curso de Desenvolvimento de Software Multiplataforma da Fatec de
              Jacareí.
            </p>
            <p>
              O Objetivo é criar um portal web voltado à certificação interna em
              metodologias ágeis, no qual o usuário se cadastra e realiza
              avaliações por níveis de dificuldade. Integrando, em um único
              projeto, os conteúdos do semestre: construção de páginas com HTML,
              CSS e JavaScript (sem frameworks), persistência de dados em
              PostgreSQL (DDL e DML), e organização do trabalho por Scrum e
              práticas ágeis básicas.
            </p>
            <!-- <img src="../assets/img/corvo.png" class="corvo_sobre_projeto" /> -->
            <!-- Dar um jeito de usar o corvo aqui embaixo para ajudar na respnsividade, mas caso não seja possivel manter ele ali onde está e implementar um javascript -->
          </div>
        </div>
      </div>
    </main>

    <!-- RODAPÉ -->
    <%- include('partials/footer') %>

    <!-- PAINEL LATERAL DE LOGIN E CADASTRO -->
    <div class="overlay_escuro" id="overlayEscuro"></div>
    <div class="painel_auth" id="painelAuth">
      <div class="painel_auth_conteudo">
        <!-- BOTÃO FECHAR -->
        <button class="botao_fechar" id="fecharAuth">
          <img src="../assets/img/icone_voltar.png" alt="Fechar painel" />
        </button>

        <!-- FORMULÁRIO LOGIN -->
        <%- include('partials/formulario_login') %>

        <!-- FORMULÁRIO CADASTRO -->
        <%- include('partials/formulario_cadastro') %>

      </div>
    </div>
    <script src="/js/main.js"></script>
    <script src="/js/index.js"></script>
    <script src="/js/auth.js"></script>
    
  </body>
</html>